{
  "_migration": {
    "ignorePaths": [
      "gateway.api",
      "gateway.api.keys"
    ],
    "removePaths": [
      "telegram.allowedUsers",
      "telegram.dmPolicy",
      "claude.dangerouslySkipPermissions"
    ]
  },
  "configVersion": "1.0.14",
  "gateway": {
    "logDir": "~/.claude-gateway/logs",
    "timezone": "Asia/Bangkok",
    "bind": "127.0.0.1",
    "models": [
      { "id": "claude-fable-5[1m]",        "label": "Fable 5 (1M)",     "alias": "fable[1m]",   "contextWindow": 1000000 },
      { "id": "claude-opus-4-8[1m]",       "label": "Opus 4.8 (1M)",    "alias": "opus[1m]",    "contextWindow": 1000000 },
      { "id": "claude-sonnet-5[1m]",       "label": "Sonnet 5 (1M)",    "alias": "sonnet[1m]",  "contextWindow": 1000000 },
      { "id": "claude-fable-5",            "label": "Fable 5",          "alias": "fable",       "contextWindow": 200000 },
      { "id": "claude-opus-4-8",           "label": "Opus 4.8",         "alias": "opus",        "contextWindow": 200000 },
      { "id": "claude-opus-4-6",           "label": "Opus 4.6",         "alias": "opus46",      "contextWindow": 200000 },
      { "id": "claude-sonnet-5",           "label": "Sonnet 5",         "alias": "sonnet",      "contextWindow": 200000 },
      { "id": "claude-sonnet-4-6",         "label": "Sonnet 4.6",       "alias": "sonnet46",    "contextWindow": 200000 },
      { "id": "claude-haiku-4-5-20251001", "label": "Haiku 4.5",        "alias": "haiku",       "contextWindow": 200000 }
    ],
    "api": {
      "keys": [
        {
          "key": "${MY_API_KEY}",
          "description": "Internal app",
          "agents": ["alfred"]
        },
        {
          "key": "${ADMIN_API_KEY}",
          "description": "Admin — full access",
          "agents": "*"
        }
      ]
    },
    "history": {
      "retentionDays": 60,
      "cleanupHour": 0,
      "cleanupTimezone": "UTC"
    },
    "headless": true,
    "selfHealing": {
      "autoRecover": false
    }
  },
  "agents": [
    {
      "id": "alfred",
      "description": "Personal assistant — handles private messages from the owner",
      "workspace": "~/.claude-gateway/agents/alfred/workspace",
      "env": "~/.claude-gateway/agents/alfred/.env",
      "telegram": {
        "botToken": "${ALFRED_BOT_TOKEN}"
      },
      "claude": {
        "model": "claude-opus-4-6",
        "extraFlags": []
      },
      "signatureEmoji": "",
      "heartbeat": {
        "rateLimitMinutes": 30
      },
      "session": {
        "idleTimeoutMinutes": 30,
        "maxConcurrent": 20
      },
      "history": {
        "retentionDays": 90
      }
    },
    {
      "id": "baerbel",
      "description": "Team support bot — open to all users",
      "workspace": "~/.claude-gateway/agents/baerbel/workspace",
      "env": "~/.claude-gateway/agents/baerbel/.env",
      "telegram": {
        "botToken": "${BAERBEL_BOT_TOKEN}"
      },
      "line": {
        "channelAccessToken": "${BAERBEL_LINE_CHANNEL_ACCESS_TOKEN}",
        "channelSecret": "${BAERBEL_LINE_CHANNEL_SECRET}"
      },
      "claude": {
        "model": "claude-sonnet-4-6",
        "extraFlags": []
      },
      "session": {
        "idleTimeoutMinutes": 30,
        "maxConcurrent": 20
      }
    }
  ]
}

{
  "_migration": {
    "ignorePaths": [
      "gateway.api",
      "gateway.api.keys"
    ],
    "removePaths": [
      "telegram.allowedUsers",
      "telegram.dmPolicy"
    ]
  },
  "configVersion": "1.0.5",
  "gateway": {
    "logDir": "~/.claude-gateway/logs",
    "timezone": "Asia/Bangkok",
    "models": [
      { "id": "claude-opus-4-7",           "label": "Opus 4.7",   "alias": "opus",   "contextWindow": 1000000 },
      { "id": "claude-opus-4-6",           "label": "Opus 4.6",   "alias": "opus46", "contextWindow": 1000000 },
      { "id": "claude-sonnet-4-6",         "label": "Sonnet 4.6", "alias": "sonnet", "contextWindow": 1000000 },
      { "id": "claude-haiku-4-5-20251001", "label": "Haiku 4.5",  "alias": "haiku",  "contextWindow": 200000 }
    ],
    "api": {
      "keys": [
        {
          "key": "${MY_API_KEY}",
          "description": "Internal app",
          "agents": ["alfred"]
        },
        {
          "key": "${ADMIN_API_KEY}",
          "description": "Admin — full access",
          "agents": "*"
        }
      ]
    },
    "history": {
      "retentionDays": 60,
      "cleanupHour": 0,
      "cleanupTimezone": "UTC"
    }
  },
  "agents": [
    {
      "id": "alfred",
      "description": "Personal assistant — handles private messages from the owner",
      "workspace": "~/.claude-gateway/agents/alfred/workspace",
      "env": "~/.claude-gateway/agents/alfred/.env",
      "telegram": {
        "botToken": "${ALFRED_BOT_TOKEN}"
      },
      "claude": {
        "model": "claude-opus-4-6",
        "dangerouslySkipPermissions": true,
        "extraFlags": []
      },
      "signatureEmoji": "",
      "heartbeat": {
        "rateLimitMinutes": 30
      },
      "session": {
        "idleTimeoutMinutes": 30,
        "maxConcurrent": 20
      },
      "history": {
        "retentionDays": 90
      }
    },
    {
      "id": "baerbel",
      "description": "Team support bot — open to all users",
      "workspace": "~/.claude-gateway/agents/baerbel/workspace",
      "env": "~/.claude-gateway/agents/baerbel/.env",
      "telegram": {
        "botToken": "${BAERBEL_BOT_TOKEN}"
      },
      "claude": {
        "model": "claude-sonnet-4-6",
        "dangerouslySkipPermissions": false,
        "extraFlags": []
      },
      "session": {
        "idleTimeoutMinutes": 30,
        "maxConcurrent": 20
      }
    }
  ]
}

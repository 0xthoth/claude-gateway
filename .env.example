# Claude Gateway — Environment Variables
# Copy to .env (or set in your shell) before running.

# ── Gateway ──────────────────────────────────────────────────────────────────

# Path to gateway config (default: ~/.claude-gateway/config.json)
# GATEWAY_CONFIG=~/.claude-gateway/config.json

# HTTP port for the gateway web UI / health check (default: 10850)
# PORT=10850
# Bind address for the gateway HTTP server (default: 0.0.0.0)
# Set to 127.0.0.1 if a host-network reverse proxy (e.g. Traefik) is used
# GATEWAY_BIND=127.0.0.1

# ── Advanced ─────────────────────────────────────────────────────────────────

# Override the claude binary (useful for testing with a mock)
# CLAUDE_BIN=claude

# Override the Telegram API base URL (useful for local testing / mocks)
# TELEGRAM_API_BASE=https://api.telegram.org

# ── Browser Module ────────────────────────────────────────────────────────────

# URL of the getpod-browser service (default: http://127.0.0.1:10880)
# GETPOD_BROWSER_URL=http://127.0.0.1:10880

# Set to true to disable the browser module entirely
# GETPOD_BROWSER_DISABLED=true

# Per-VM key for getpod-browser authentication (injected at provision; leave empty for local dev)
# GETPOD_BROWSER_API_KEY=

# ── Image Module (generate_image) ─────────────────────────────────────────────

# Image generation may target a provider separate from the LLM. These override
# ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN for image calls; leave unset to reuse
# the same provider that fronts /v1/images/{generations,jobs}.
# IMAGE_BASE_URL=
# IMAGE_API_KEY=

# Set to true to disable the image module entirely
# IMAGE_DISABLED=true

# Poll budget (ms) before handing the task_id back for action="status" (default 150000)
# IMAGE_POLL_TIMEOUT_MS=150000
